# ============================================
#  数学 AI 后端配置模板
#  用法：复制本文件为 .env （命令：cp .env.example .env），按需填写
#  注意：不配置任何 API Key 也能运行（系统自动使用本地规则讲解）
# ============================================

# 后端端口（默认 3001）
PORT=3001

# 选择讲解用的大模型：claude | openai | deepseek | mock
# mock = 不调用任何 AI，全部使用本地规则讲解（默认）
LLM_PROVIDER=mock

# —— Claude（Anthropic）——
# 当 LLM_PROVIDER=claude 时生效
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# —— OpenAI ——
# 当 LLM_PROVIDER=openai 时生效
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# —— DeepSeek ——
# 当 LLM_PROVIDER=deepseek 时生效
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
